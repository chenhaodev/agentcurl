# --- DeepSeek-V4-Flash (OpenAI-compatible) — powers structured extraction ---
DEEPSEEK_API_KEY=your_key_here
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_TIMEOUT=60
DEEPSEEK_MAX_RETRIES=3

# --- crawl backend: static | browser | crawl4ai | firecrawl | jina | a "+"-list ---
CRAWL_BACKEND=static
ROUTER_MODE=fallback                 # for a "+"-list: fallback (first non-empty) | fan-out

# --- crawl limits (shared across backends) ---
CRAWL_DEPTH=1                        # link-following depth for crawl()
CRAWL_MAX_PAGES=20                   # hard cap on pages per crawl()
REQUEST_TIMEOUT=30                   # per-request HTTP timeout (seconds)
RATE_LIMIT_DELAY=0                   # seconds between same-domain fetches (be polite)
RESPECT_ROBOTS=1                     # honor robots.txt on the link-walk crawl
# CRAWL_USER_AGENT=agentcurl/0.1 (+https://github.com/chenhaodev/agentcurl)

# --- browser backend (Playwright) — needs: pip install "agentcurl[browser]" && playwright install chromium ---
BROWSER_HEADLESS=1
BROWSER_WAIT_UNTIL=networkidle       # load | domcontentloaded | networkidle
BROWSER_TIMEOUT=30

# --- crawl4ai backend — needs: pip install "agentcurl[crawl4ai]" && crawl4ai-setup ---
CRAWL4AI_FIT_MARKDOWN=1              # use pruned "fit" markdown tuned for LLMs

# --- firecrawl backend (managed REST API) — get a key at https://firecrawl.dev ---
FIRECRAWL_API_KEY=
FIRECRAWL_API_BASE=https://api.firecrawl.dev

# --- jina backend (r.jina.ai reader) — key optional, raises rate limits ---
JINA_API_KEY=
JINA_API_BASE=https://r.jina.ai

# --- meta-learning layer (per-domain recipes: learn once, reuse next time) ---
AGENTCURL_LEARN=1                    # record per-domain outcomes + auto-apply learned recipes
AGENTCURL_RECIPES_DIR=.agentcurl/recipes   # where learned recipes + login sessions are stored
# Tip: set CRAWL_BACKEND=auto to let agentcurl route each domain to the backend
# it has learned works best there (defaults to static until something is learned).
# Capture a login once with:  python -m agentcurl <url> --learn-login
